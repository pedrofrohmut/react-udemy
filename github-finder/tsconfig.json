{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "es2023",
        "lib": ["ES2023", "DOM"],
        "module": "esnext",
        "types": ["vite/client", "node"],
        "skipLibCheck": true,

        "jsx": "react-jsx",
        "noEmit": true,

        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": ["src", "vite.config.ts"],
    "exclude": ["**/node_modules/"]
}
